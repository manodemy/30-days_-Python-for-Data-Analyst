{
  "version": 2,
  "framework": "nextjs",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://checkout.razorpay.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https://*.supabase.co https://*.razorpay.com https://img.youtube.com https://*.googleusercontent.com https://*.githubusercontent.com https://*.gravatar.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.razorpay.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com; frame-src 'self' https://api.razorpay.com https://www.youtube.com https://www.youtube-nocookie.com;" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
      ]
    },
    {
      "source": "/notebook/day:day(0[3-9]|[12][0-9]|30)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/notebook/sql-day:day(0[1-9]|1[0-8])",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/notebook/excel-day:day(0[3-9]|1[0-2])",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, no-cache, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/supabase.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/chart.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/Version-3/content/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/sql/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/landing_v2/index.html",
      "permanent": true
    },
    {
      "source": "/day:day(0[3-9]|[12][0-9]|30).html",
      "destination": "/notebook/day:day",
      "permanent": true
    },
    {
      "source": "/sql/day:day(0[3-9]|1[0-8]).html",
      "destination": "/notebook/sql-day:day",
      "permanent": false
    },
    {
      "source": "/excel/day:day(0[3-9]|1[0-2]).html",
      "destination": "/notebook/excel-day:day",
      "permanent": true
    },
    {
      "source": "/sql/day:day(0[3-9]|1[0-8])",
      "destination": "/notebook/sql-day:day",
      "permanent": true
    },
    {
      "source": "/excel/day:day(0[1-2])",
      "destination": "/excel/day:day.html",
      "permanent": true
    },
    {
      "source": "/excel/day:day(0[3-9]|1[0-2])",
      "destination": "/notebook/excel-day:day",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/landing_v2/privacy.html",
      "permanent": false
    },
    {
      "source": "/terms",
      "destination": "/landing_v2/terms.html",
      "permanent": false
    },
    {
      "source": "/refund-policy",
      "destination": "/landing_v2/refund-policy.html",
      "permanent": false
    },
    {
      "source": "/reset-password",
      "destination": "/landing_v2/reset-password.html",
      "permanent": false
    },
    {
      "source": "/payment-success",
      "destination": "/landing_v2/payment-success.html",
      "permanent": false
    },
    {
      "source": "/payment-failed",
      "destination": "/landing_v2/payment-failed.html",
      "permanent": false
    },

    {
      "source": "/sql-course",
      "destination": "/landing_v2/sql-course.html",
      "permanent": false
    },
    {
      "source": "/excel-course",
      "destination": "/landing_v2/excel-course.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/notebook/sql-day:day(0[1-9]|1[0-8])",
      "destination": "/sql/day:day.html"
    },
    {
      "source": "/python",
      "destination": "/python/index.html"
    },
    {
      "source": "/day01.html",
      "destination": "/python/index.html?day=1"
    },
    {
      "source": "/day02.html",
      "destination": "/python/index.html?day=2"
    }
  ]
}
